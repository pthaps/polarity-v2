{
  "manifest_version": 3,
  "name": "Polarity AI",
  "version": "1.0.0",
  "description": "Analyze news articles for political bias and reliability (Ad Fontes–informed).",
  "permissions": ["activeTab", "storage"],
  "host_permissions": ["http://localhost:3000/*", "http://127.0.0.1:3000/*", "https://*/*"],
  "action": {
    "default_title": "Polarity AI",
    "default_popup": "popup.html"
  },
  "options_page": "options.html"
}
